# KORE Dashboard FastAPI Backend Configuration
# Copy this file to .env and fill in your values

# Required: Your AI API Key (Gemini or Groq)
# The system automatically detects which provider to use based on the key prefix:
#   - Gemini keys start with: AIzaSy
#   - Groq keys start with: gsk_
#
# Get Gemini API key at: https://makersuite.google.com/app/apikey
# Get Groq API key at: https://console.groq.com/keys
#
# Default (Gemini):
GEMINI_API_KEY=AIzaSyAa-AyiIcmiRq4MQYkNOSq9D3ZxFQLmvqw
#
# Or use Groq (uncomment to switch):
# GEMINI_API_KEY=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

# Optional: Frontend URL for CORS (defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Optional: Server port (defaults to 8000)
PORT=8000

# Optional: Environment (development, production, staging)
ENVIRONMENT=development

# Optional: Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60
